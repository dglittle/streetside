# Copy this file to .env.local and fill in the values from your Supabase project.
# Supabase dashboard -> Project Settings -> API
#
# These are PUBLIC (anon) keys exposed to the browser. That is expected and safe
# as long as Row Level Security (RLS) is enabled on your tables (it is, by default).
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
